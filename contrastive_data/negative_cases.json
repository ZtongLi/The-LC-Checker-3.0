[
  {
    "id": "NEG_001",
    "category": "name_equivalence",
    "scenario": "公司名称等价缩写差异 — 不构成不符",
    "lc_field": {
      "field": "beneficiary.name",
      "value": "ABC Trading Co., Ltd."
    },
    "doc_field": {
      "document": "commercial_invoice",
      "field": "issued_by",
      "value": "ABC Trading Company Limited"
    },
    "is_discrepancy": false,
    "explanation": "'Co., Ltd.' 与 'Company Limited' 是国际贸易中公认的等价缩写形式，根据 ISBP 745 惯例不构成不符点。 重要提醒：此规则仅适用于信用证本身使用了缩写形式的情况。如果信用证使用全称 Company Limited，而单据使用 Co., Ltd.，则仍可能构成不符点，需结合具体信用证条款判断。"
  },
  {
    "id": "NEG_002",
    "category": "name_equivalence",
