# ============================================
# 信用证智能审单系统 - 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================

# OpenAI API 配置（用于 AI 审单）
# 必填：你的 OpenAI API Key
OPENAI_API_KEY=your_api_key_here

# 可选：API 基础地址（使用代理时修改）
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_BASE=https://your-proxy-domain.com/v1

# 可选：使用的模型名称
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL=gpt-3.5-turbo

# 工作目录（容器内使用，通常无需修改）
# WORK_DIR=/app
